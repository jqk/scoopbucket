{
    "version": "8.14.5",
    "description": "An open-source build automation tool focused on flexibility and performance. (Binaries only without documentation)",
    "homepage": "https://gradle.org",
    "license": "Apache-2.0",
    "suggest": {
        "JDK": "java/openjdk"
    },
    "url": "https://services.gradle.org/distributions/gradle-8.14.5-bin.zip",
    "hash": "6f74b601422d6d6fc4e1f9a1ab6522f642c2fdcbc15ae33ebd30ba3d7198e854",
    "extract_dir": "gradle-8.14.5",
    "post_install": [
        "$current_env = [System.Environment]::GetEnvironmentVariable('GRADLE_USER_HOME', 'User')",
        "If ($null -eq $current_env) {",
        "    $path = \"$dir\\.gradle\"",
        "    [System.Environment]::SetEnvironmentVariable('GRADLE_USER_HOME', $path, 'User')",
        "    $Env:GRADLE_USER_HOME = $path",
        "    Write-Host \"Environment variable 'GRADLE_USER_HOME' set to '$path'\"",
        "}"
    ],
    "persist": [
        ".gradle",
        "caches"
    ],
    "bin": "bin\\gradle.bat",
    "checkver": {
        "url": "https://gradle.org/releases/",
        "regex": ">([\\d.]+)</a>"
    },
    "autoupdate": {
        "url": "https://services.gradle.org/distributions/gradle-$version-bin.zip",
        "hash": {
            "url": "$url.sha256"
        },
        "extract_dir": "gradle-$version"
    }
}
